{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "The display name of the user." },
        "email": { "type": "string", "description": "The email address of the user." },
        "photoURL": { "type": "string", "description": "The profile photo URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." }
      },
      "required": ["uid", "email"]
    },
    "Ad": {
      "title": "Ad",
      "description": "A service advertisement posted by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string", "description": "The UID of the user who posted the ad." },
        "authorName": { "type": "string" },
        "category": { "type": "string", "enum": ["washing_machine", "transport", "meal"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number", "description": "Price if applicable, or 0 for free." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "category", "title", "description", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message sent between neighbors regarding an ad.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "adId": { "type": "string", "description": "The ID of the ad this message is about." },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "receiverId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["adId", "senderId", "receiverId", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/ads/{adId}": {
      "schema": "Ad",
      "description": "Service advertisements."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Direct messages between users."
    }
  }
}
